<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="ApiSoap" />
            </basicHttpBinding>
        </bindings>
        <client>
            <endpoint address="http://localhost:44356/API.asmx" binding="basicHttpBinding"
                bindingConfiguration="ApiSoap" contract="KMCEventService.ApiSoap"
                name="ApiSoap" />
        </client>
    </system.serviceModel>
</configuration>
